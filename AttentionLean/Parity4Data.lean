/-
  AttentionLean.Parity4Data
  Definitions for the n=4 parity impossibility computation.
-/
import Mathlib

open Finset

def decodeFin4 (i : Fin 16) : Fin 4 → Bool := fun j =>
  match j with
  | 0 => i.val % 2 == 1
  | 1 => (i.val / 2) % 2 == 1
  | 2 => (i.val / 4) % 2 == 1
  | 3 => (i.val / 8) % 2 == 1

def cWinner4 (s0 s1 s2 s3 : ℕ) : Fin 4 :=
  if s0 ≥ s1 ∧ s0 ≥ s2 ∧ s0 ≥ s3 then 0
  else if s1 ≥ s2 ∧ s1 ≥ s3 then 1
  else if s2 ≥ s3 then 2
  else 3

def cOutput4 (s : Fin 4 → Bool → Fin 8) (r : Fin 4 → Bool → Bool) (i : Fin 16) : Bool :=
  let x := decodeFin4 i
  let w := cWinner4 (s 0 (x 0)).val (s 1 (x 1)).val (s 2 (x 2)).val (s 3 (x 3)).val
  r w (x w)

