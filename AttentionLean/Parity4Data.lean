def achievable4Bits : ℕ := achievable4Raw.foldl (fun acc n => acc ||| (1 <<< n)) 0

def hasCollision4 (f1 f2 f3 : ℕ) : Bool :=
  [0, 3, 5, 6, 9, 10, 12, 15].any fun e =>
    [1, 2, 4, 7, 8, 11, 13, 14].any fun o =>
      f1.testBit e == f1.testBit o &&
      f2.testBit e == f2.testBit o &&
      f3.testBit e == f3.testBit o
